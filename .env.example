# =========================
# App
# =========================
APP_NAME=Cloud Edge Inspection Platform
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# =========================
# Database
# =========================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=inspection_platform
POSTGRES_USER=inspection_user
POSTGRES_PASSWORD=inspection_password

# =========================
# Redis
# =========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =========================
# JWT
# =========================
JWT_SECRET_KEY=please_change_this_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =========================
# MQTT
# =========================
MQTT_HOST=mqtt
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# =========================
# File Storage
# =========================
UPLOAD_DIR=uploads

# =========================
# Log
# =========================
LOG_LEVEL=INFO
EOF